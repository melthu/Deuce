# --- Python ---
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/

# --- Local noise ---
.DS_Store
# CatBoost's training log. The trainers pass allow_writing_files=False so this
# should no longer appear; kept ignored for older checkouts.
catboost_info/
# Scratch notes for the in-flight static-site migration; delete when it lands
HANDOFF.md
# Agent-facing architecture reference; kept locally, not part of the published repo
CLAUDE.md

# --- Build output (regenerable; do not commit) ---
# `make features` rebuilds these from data/raw in ~26s. data/raw is the only
# scraped input worth tracking; everything downstream of it is derived.
data/interim/
data/processed/
# `make export` rebuilds this from data/processed; ~9 MB across ~690 files.
# The workflow builds it fresh and uploads it as a Pages artifact.
site/data/

# --- Models ---
# Only the promoted model and the Optuna params are tracked. The per-candidate
# pickles are benchmark artifacts rebuilt by `make train`, and the weekly
# workflow only ever commits best_model.pkl.
models/*
!models/best_model.pkl
!models/best_params.json
