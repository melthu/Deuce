# --- Python ---
__pycache__/
*.py[cod]
.venv/

# --- Local noise ---
.DS_Store
catboost_info/

# --- Build output (regenerable; do not commit) ---
# `make features` rebuilds these from data/raw
data/interim/
# `make export` rebuilds this from data/processed; ~9 MB across ~690 files.
# The workflow builds it fresh and uploads it as a Pages artifact.
site/data/

# --- Models ---
# Only the promoted model and the Optuna params are tracked. The per-candidate
# pickles are benchmark artifacts rebuilt by `make train`, and the weekly
# workflow only ever commits best_model.pkl.
models/*
!models/best_model.pkl
!models/best_params.json
